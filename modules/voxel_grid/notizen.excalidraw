    {
      "id": "KT2zB1NiC-JULELttk5LW",
      "type": "text",
      "x": -110.52534402737365,
      "y": -1962.6931578607791,
      "width": 3733.0037463605404,
      "height": 322.64318847656244,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2C",
      "roundness": null,
      "seed": 1468742930,
      "version": 803,
      "versionNonce": 1830931598,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773319732150,
      "link": null,
      "locked": false,
      "text": "Mir ist gerade was bezgl. der PyhiskEngine aufgefallen:\n- Wenn alle RIDs sortiert sind, mach ich das mit meiner Technik \"n\" viele aufeinmal zu bearbeiten kapput\n- Es funktionier jedoch wieder, wenn man nur die \"first_shapes\" beachtet. Ist die frage, ob intern irgentwo doch ein BinarySearch implementiert ist...\n- Sollte ich irgendwann \"Platz dafür haben\", könnte ich mir die RIDs angucken und vieleicht einige der Bits für \"shape_count\" nutzen.\n",
      "fontSize": 51.62291015625001,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mir ist gerade was bezgl. der PyhiskEngine aufgefallen:\n- Wenn alle RIDs sortiert sind, mach ich das mit meiner Technik \"n\" viele aufeinmal zu bearbeiten kapput\n- Es funktionier jedoch wieder, wenn man nur die \"first_shapes\" beachtet. Ist die frage, ob intern irgentwo doch ein BinarySearch implementiert ist...\n- Sollte ich irgendwann \"Platz dafür haben\", könnte ich mir die RIDs angucken und vieleicht einige der Bits für \"shape_count\" nutzen.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MCWK3XGS0kmHK_RGirKvi",
      "type": "text",
      "x": -185.9680329503476,
      "y": -699.6576327343258,
      "width": 1620.0793850237606,
      "height": 112.25762352027168,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
