      "seed": 952324908,
      "version": 790,
      "versionNonce": 1380967980,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773324571276,
      "link": null,
      "locked": false,
      "text": "Bei großen Grids muss ein \"künstlicher\" Origin nahe am Spieler erstellt\nwerden, damit floatingpointerrors nicht sichtbar werden!",
      "fontSize": 44.90304940810867,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bei großen Grids muss ein \"künstlicher\" Origin nahe am Spieler erstellt werden, damit floatingpointerrors nicht sichtbar werden!",
      "autoResize": false,
      "lineHeight": 1.25
    },
